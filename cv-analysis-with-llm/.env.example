# LLM Provider: ollama | gemini | openai | anthropic
LLM_PROVIDER=ollama
LLM_MODEL=moondream

# Provider API keys (only needed for cloud providers)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama host (only needed for ollama provider)
OLLAMA_HOST=http://localhost:11434

# Detection
FPS=5
BUFFER_SECONDS=5
ANALYSIS_INTERVAL=30

# Camera mode — single (now) | multi (future)
CAMERA_MODE=single

# Path to cameras config
CAMERAS_CONFIG=vision_config.yaml

# Log files
EVENTS_LOG_FILE=logs/events.log
NOTIFICATIONS_ENABLED=false
GMAIL_SENDER=your@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here   # Google App Password, not your real password
GMAIL_RECIPIENT=notify@gmail.com
# Only notify when these keywords appear in actions/objects/people (comma separated)
NOTIFY_ON_KEYWORDS=person,motion,unknown